{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signallake.dev/schemas/event-catalog.v1.json",
  "title": "SignalLake Event Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "catalogVersion",
    "product",
    "appId",
    "owner",
    "status",
    "commonFieldsVersion",
    "privacyRulesVersion",
    "events"
  ],
  "properties": {
    "schemaVersion": {
      "const": "signallake.event-catalog.v1"
    },
    "catalogVersion": {
      "type": "string",
      "pattern": "^signallake\\.catalog\\.[a-z0-9.-]+\\.v[0-9]+$",
      "maxLength": 96
    },
    "product": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "appId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(\\.[a-z0-9-]+)+$",
      "maxLength": 96
    },
    "owner": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "removed"
      ]
    },
    "commonFieldsVersion": {
      "const": "signallake.common-fields.v1"
    },
    "privacyRulesVersion": {
      "const": "signallake.privacy-rules.v1"
    },
    "generatedFromManifest": {
      "type": "string",
      "maxLength": 160
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "category",
          "privacyClass",
          "status",
          "owner",
          "since",
          "properties"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)+$",
            "maxLength": 96
          },
          "category": {
            "type": "string",
            "enum": [
              "lifecycle",
              "screen",
              "command",
              "error",
              "domain",
              "media",
              "system"
            ]
          },
          "privacyClass": {
            "type": "string",
            "enum": [
              "operational",
              "behavioral",
              "diagnostic"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "active",
              "deprecated",
              "removed"
            ]
          },
          "owner": {
            "type": "string",
            "minLength": 1,
            "maxLength": 96
          },
          "since": {
            "type": "string",
            "pattern": "^signallake\\.[a-z0-9.-]+\\.v[0-9]+$|^[0-9]+\\.[0-9]+\\.[0-9]+$",
            "maxLength": 80
          },
          "deprecatedSince": {
            "type": "string",
            "pattern": "^signallake\\.[a-z0-9.-]+\\.v[0-9]+$|^[0-9]+\\.[0-9]+\\.[0-9]+$",
            "maxLength": 80
          },
          "replacedBy": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)+$",
            "maxLength": 96
          },
          "properties": {
            "type": "array",
            "maxItems": 50,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "type",
                "scope",
                "required",
                "description"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "pattern": "^[a-z][a-zA-Z0-9_]{0,63}$"
                },
                "type": {
                  "type": "string",
                  "enum": [
                    "string",
                    "number",
                    "integer",
                    "boolean"
                  ]
                },
                "scope": {
                  "type": "string",
                  "enum": [
                    "common",
                    "product"
                  ]
                },
                "required": {
                  "type": "boolean"
                },
                "since": {
                  "type": "string",
                  "pattern": "^signallake\\.[a-z0-9.-]+\\.v[0-9]+$|^[0-9]+\\.[0-9]+\\.[0-9]+$",
                  "maxLength": 80
                },
                "deprecatedSince": {
                  "type": "string",
                  "pattern": "^signallake\\.[a-z0-9.-]+\\.v[0-9]+$|^[0-9]+\\.[0-9]+\\.[0-9]+$",
                  "maxLength": 80
                },
                "enum": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 64
                  }
                },
                "description": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 240
                }
              }
            }
          }
        }
      }
    }
  }
}
